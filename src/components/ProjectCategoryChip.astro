---
import { PROJECT_CATEGORIES, type ProjectCategoryName } from '../consts';

interface Props {
	category: ProjectCategoryName;
	linked?: boolean;
	variant?: 'light' | 'dark';
}

const { category, linked = true, variant = 'light' } = Astro.props;
const info = PROJECT_CATEGORIES[category];
const href = `/projects/category/${info.slug}/`;
const style = `--cat-color: ${info.color}; --cat-bg: ${info.bg}; --cat-text: ${info.text};`;
---

{
	linked ? (
		<a class:list={['cat-chip', variant]} href={href} style={style}>
			{category}
		</a>
	) : (
		<span class:list={['cat-chip', variant]} style={style}>
			{category}
		</span>
	)
}

<style>
	.cat-chip {
		display: inline-block;
		padding: 0.3em 0.8em;
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border-radius: 4px;
		font-weight: 600;
		line-height: 1.4;
		font-family: var(--font-sans);
		text-decoration: none;
		white-space: nowrap;
		transition: transform 0.15s, filter 0.15s, background 0.15s;
	}
	.cat-chip.light {
		background: var(--cat-bg);
		color: var(--cat-text);
		border: 1px solid color-mix(in srgb, var(--cat-color) 35%, transparent);
	}
	.cat-chip.dark {
		background: color-mix(in srgb, var(--cat-color) 15%, transparent);
		color: var(--cat-color);
		border: 1px solid color-mix(in srgb, var(--cat-color) 55%, transparent);
	}
	a.cat-chip:hover {
		transform: translateY(-1px);
		filter: brightness(1.08);
		text-decoration: none;
	}
	a.cat-chip.light:hover {
		background: color-mix(in srgb, var(--cat-color) 18%, transparent);
	}
	a.cat-chip.dark:hover {
		background: color-mix(in srgb, var(--cat-color) 24%, transparent);
	}
</style>
