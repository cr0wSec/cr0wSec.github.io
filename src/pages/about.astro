---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description="About the author and this blog." />
		<style>
			.page-hero {
				background:
					radial-gradient(circle at 15% 20%, rgba(0, 80, 50, 0.35), transparent 50%),
					radial-gradient(circle at 85% 80%, rgba(0, 60, 80, 0.4), transparent 50%),
					linear-gradient(135deg, #0a2618 0%, #0c2d3a 45%, #050d12 100%);
				color: var(--white);
				padding: 4em 1em 3.5em;
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				position: relative;
				overflow: hidden;
			}
			.page-hero::after {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
				background-size: 48px 48px;
				mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
				pointer-events: none;
			}
			.page-hero .hero-inner {
				position: relative;
				max-width: var(--wide-width);
				margin: 0 auto;
				z-index: 1;
			}
			.page-hero h1 {
				color: var(--white);
				font-size: clamp(1.75rem, 4vw, 2.75rem);
				margin: 0 0 0.4em;
			}
			.page-hero p {
				color: rgba(255, 255, 255, 0.75);
				margin: 0;
				max-width: 62ch;
				font-size: 1.05rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="page-hero">
			<div class="hero-inner">
				<h1>About</h1>
				<p>About the author and this blog.</p>
			</div>
		</section>
		<main id="main-content">
			<h2>Hi, I'm {AUTHOR}.</h2>
			<p>
				This site is where I publish notes, experiments, and research on security — both offense and
				defense, and everything in between. The tone is practical and opinionated. The goal is to
				share things I wish I had found when I was first working through a problem.
			</p>

			<h3>What you'll find here</h3>
			<ul>
				<li>
					<strong>Offensive Security</strong> — exploitation, red teaming, tradecraft, and the
					attacker mindset all the way to shell.
				</li>
				<li>
					<strong>Detection Engineering</strong> — building and tuning detections, test harnesses,
					telemetry coverage, and the long tail of false positives.
				</li>
				<li>
					<strong>Threat Intelligence</strong> — actor tracking, TTP analysis, and campaign
					write-ups.
				</li>
				<li>
					<strong>OSINT</strong> — techniques, case studies, tooling, and tradecraft.
				</li>
				<li>
					<strong>Cryptography</strong> — protocol deep-dives, implementation pitfalls, and the
					places where theory meets production.
				</li>
				<li>
					<strong>Post-Quantum</strong> — NIST finalists, hybrid schemes, and real-world migration
					strategy.
				</li>
			</ul>

			<h3>Ground rules</h3>
			<p>
				Everything here reflects personal views and is offered for educational purposes only. I write
				about both offensive and defensive work, plus open-source research. Corrections and pull
				requests are welcome.
			</p>

			<h3>Get in touch</h3>
			<p>
				The fastest way to reach me is via the links in the footer.
			</p>
		</main>
		<Footer />
	</body>
</html>
