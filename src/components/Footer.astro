---
import { AUTHOR, SITE_TITLE, SOCIAL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<strong>{SITE_TITLE}</strong>
			<p>Notes and research on offensive and defensive security, threat intel, and cryptography.</p>
		</div>
		<div class="footer-links">
			<div class="col">
				<h4>Site</h4>
				<a href="/">Home</a>
				<a href="/blog">Blog</a>
				<a href="/projects">Projects</a>
				<a href="/about">About</a>
			</div>
			<div class="col">
				<h4>Elsewhere</h4>
				<a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">GitHub</a>
			</div>
		</div>
	</div>
	<div class="copy">
		<span>&copy; {today.getFullYear()} {AUTHOR}. All rights reserved.</span>
		<span class="built">Built with Astro.</span>
	</div>
</footer>

<style>
	footer {
		background: #020c10;
		color: rgba(255, 255, 255, 0.72);
		padding: 3.5em 1em 2em;
		border-top: 1px solid var(--navy-700);
		margin-top: auto;
	}
	.footer-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2.5em;
		flex-wrap: wrap;
		padding-bottom: 2.5em;
		border-bottom: 1px solid var(--navy-700);
	}
	.footer-brand {
		max-width: 34ch;
	}
	.footer-brand strong {
		color: var(--white);
		font-size: 1.1rem;
	}
	.footer-brand p {
		margin: 0.5em 0 0;
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.6);
	}
	.footer-links {
		display: flex;
		gap: 3em;
		flex-wrap: wrap;
	}
	.footer-links .col {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.footer-links h4 {
		color: var(--white);
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		margin: 0 0 0.5em;
	}
	.footer-links a {
		color: rgba(255, 255, 255, 0.65);
		text-decoration: none;
		font-size: 0.92rem;
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.copy {
		max-width: var(--wide-width);
		margin: 1.5em auto 0;
		font-size: 0.82rem;
		color: rgba(255, 255, 255, 0.45);
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5em;
	}
</style>
