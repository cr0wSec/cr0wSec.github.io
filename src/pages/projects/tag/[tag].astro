---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import ProjectCategoryChip from '../../../components/ProjectCategoryChip.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
	const projects = (await getCollection('projects')).filter((p) => !p.data.draft);
	const tagMap = new Map<string, CollectionEntry<'projects'>[]>();
	for (const project of projects) {
		for (const tag of project.data.tags) {
			if (!tagMap.has(tag)) tagMap.set(tag, []);
			tagMap.get(tag)!.push(project);
		}
	}
	return Array.from(tagMap.entries()).map(([tag, tagProjects]) => ({
		params: { tag },
		props: {
			tag,
			projects: tagProjects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

interface Props {
	tag: string;
	projects: CollectionEntry<'projects'>[];
}

const { tag, projects } = Astro.props;
const statusLabel = { active: 'Active', wip: 'Work in progress', archived: 'Archived' };
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`#${tag} · ${SITE_TITLE}`} description={`Projects tagged "${tag}".`} />
		<style>
			.tag-hero {
				background:
					radial-gradient(circle at 18% 25%, rgba(184, 118, 58, 0.2), transparent 45%),
					linear-gradient(135deg, var(--coal-950) 0%, var(--navy-900) 60%, var(--coal-900) 100%);
				color: var(--white);
				padding: 4em 1em 3.5em;
				border-bottom: 1px solid var(--navy-700);
			}
			.tag-hero .inner {
				max-width: var(--wide-width);
				margin: 0 auto;
			}
			.breadcrumbs {
				display: inline-flex;
				align-items: center;
				font-family: var(--font-mono);
				font-size: 0.76rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: rgba(255, 255, 255, 0.85);
				margin-bottom: 1.25em;
				font-weight: 600;
				line-height: 1;
			}
			.breadcrumbs a {
				color: rgba(255, 255, 255, 0.9);
				text-decoration: none;
			}
			.breadcrumbs a:hover {
				color: var(--accent-hover);
				text-decoration: none;
			}
			.breadcrumbs .sep {
				margin: 0 0.6em;
				color: rgba(255, 255, 255, 0.6);
			}
			.breadcrumbs .current {
				color: var(--white);
			}
			.tag-hero h1 {
				color: var(--white);
				font-size: clamp(1.8rem, 4vw, 2.4rem);
				margin: 0;
				font-family: var(--font-mono);
			}
			ul.projects {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 1.25em;
			}
			ul.projects li a {
				display: block;
				padding: 1.5em 1.75em;
				border: 1px solid var(--border);
				border-radius: 6px;
				color: inherit;
				text-decoration: none;
				transition: transform 0.15s, box-shadow 0.15s;
			}
			ul.projects li a:hover {
				transform: translateX(3px);
				box-shadow: var(--box-shadow);
			}
			.meta {
				display: flex;
				gap: 0.6em;
				align-items: center;
				margin-bottom: 0.55em;
				flex-wrap: wrap;
			}
			.meta .date {
				color: var(--text-muted);
				font-size: 0.82rem;
				font-family: var(--font-mono);
			}
			.status {
				display: inline-block;
				padding: 0.2em 0.7em;
				font-size: 0.68rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				border-radius: 4px;
				font-weight: 600;
				font-family: var(--font-sans);
				border: 1px solid var(--border);
			}
			.status.active {
				background: color-mix(in srgb, var(--accent) 10%, transparent);
				border-color: color-mix(in srgb, var(--accent) 40%, transparent);
				color: var(--accent);
			}
			.status.wip {
				background: rgba(245, 158, 11, 0.1);
				border-color: rgba(245, 158, 11, 0.4);
				color: #b45309;
			}
			.status.archived {
				background: var(--bg-muted);
				color: var(--text-muted);
			}
			h2.title {
				font-size: 1.3rem;
				margin: 0.25em 0 0.4em;
				color: var(--navy-900);
			}
			.excerpt {
				color: var(--text-muted);
				margin: 0;
				font-size: 0.95rem;
			}
			.count {
				color: var(--text-muted);
				font-family: var(--font-mono);
				font-size: 0.8rem;
				margin-bottom: 1.5em;
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="tag-hero">
			<div class="inner">
				<nav class="breadcrumbs" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span class="sep">›</span>
					<a href="/projects">Projects</a>
					<span class="sep">›</span>
					<span class="current">#{tag}</span>
				</nav>
				<h1>#{tag}</h1>
			</div>
		</section>
		<main id="main-content">
			<p class="count">
				{projects.length} {projects.length === 1 ? 'project' : 'projects'} tagged
			</p>
			<ul class="projects">
				{
					projects.map((project) => (
						<li>
							<a href={`/projects/${project.id}/`}>
								<div class="meta">
									{project.data.category && (
										<ProjectCategoryChip category={project.data.category} linked={false} />
									)}
									<span class={`status ${project.data.status}`}>
										{statusLabel[project.data.status]}
									</span>
									<span class="date">
										<FormattedDate date={project.data.pubDate} />
									</span>
								</div>
								<h2 class="title">{project.data.title}</h2>
								<p class="excerpt">{project.data.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
