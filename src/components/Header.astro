---
import { SITE_TITLE, SOCIAL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<a class="skip-link" href="#main-content">Skip to content</a>
<header>
	<nav>
		<a class="brand" href="/">
			<span class="brand-name">{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="/search" aria-label="Search">
				<span class="sr-only">Search</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
					<path
						fill="currentColor"
						d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"
					></path>
				</svg>
			</a>
			<a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	.skip-link {
		position: absolute;
		left: 0.75em;
		top: 0.75em;
		padding: 0.55em 1em;
		background: var(--accent);
		color: var(--white);
		font-weight: 600;
		border-radius: 4px;
		transform: translateY(-200%);
		transition: transform 0.15s;
		z-index: 100;
	}
	.skip-link:focus {
		transform: translateY(0);
		text-decoration: none;
		color: var(--white);
	}
	header {
		background: #020c10;
		color: var(--white);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		position: sticky;
		top: 0;
		z-index: 50;
	}
	nav {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 1.25em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.55em;
		color: var(--white);
		font-weight: 700;
		font-size: 1.05rem;
		padding: 1.1em 0;
		text-decoration: none;
		letter-spacing: -0.01em;
	}
	.brand:hover {
		color: var(--white);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 0.25em;
	}
	.internal-links :global(a) {
		padding: 0.55em 0.9em;
		color: rgba(255, 255, 255, 0.72);
		font-size: 0.95rem;
		border-radius: 6px;
		transition: color 0.15s, background 0.15s;
	}
	.internal-links :global(a:hover) {
		color: var(--white);
		background: rgba(255, 255, 255, 0.1);
		text-decoration: none;
	}
	.internal-links :global(a.active) {
		color: var(--white);
		background: rgba(255, 255, 255, 0.1);
		font-weight: 600;
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.9em;
	}
	.social-links a {
		display: inline-flex;
		color: rgba(255, 255, 255, 0.7);
		transition: color 0.15s;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 640px) {
		.social-links {
			display: none;
		}
		nav {
			gap: 0.5em;
		}
		.brand-name {
			display: none;
		}
		.internal-links :global(a) {
			padding: 0.55em 0.6em;
			font-size: 0.9rem;
		}
	}
</style>
