---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import ProjectCategoryChip from '../../components/ProjectCategoryChip.astro';
import { PROJECT_CATEGORIES, SITE_TITLE } from '../../consts';

const allProjects = (await getCollection('projects'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const activeProjects = allProjects.filter((p) => p.data.status === 'active');

const statusLabel = { active: 'Active', wip: 'Work in progress', archived: 'Archived' };
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Projects · ${SITE_TITLE}`}
			description="Things I'm building — open-source tools, research prototypes, and experiments."
		/>
		<style>
			.page-hero {
				background:
					radial-gradient(circle at 15% 20%, rgba(0, 80, 50, 0.35), transparent 50%),
					radial-gradient(circle at 85% 80%, rgba(0, 60, 80, 0.4), transparent 50%),
					linear-gradient(135deg, #0a2618 0%, #0c2d3a 45%, #050d12 100%);
				color: var(--white);
				padding: 4em 1em 3.5em;
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				position: relative;
				overflow: hidden;
			}
			.page-hero::after {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
				background-size: 48px 48px;
				mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
				pointer-events: none;
			}
			.page-hero .hero-inner {
				position: relative;
				max-width: var(--wide-width);
				margin: 0 auto;
				z-index: 1;
			}
			.page-hero h1 {
				color: var(--white);
				font-size: clamp(1.75rem, 4vw, 2.75rem);
				margin: 0 0 0.4em;
			}
			.page-hero p {
				color: rgba(255, 255, 255, 0.75);
				margin: 0;
				max-width: 62ch;
				font-size: 1.05rem;
			}

			.categories-nav {
				margin-bottom: 2.5em;
			}
			.list-section + .list-section {
				margin-top: 3em;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.25em;
				gap: 1em;
				flex-wrap: wrap;
			}
			.section-header h2 {
				font-size: 1.35rem;
				margin: 0;
				color: var(--navy-900);
			}
			.section-header .sub {
				font-size: 0.9rem;
				color: var(--text-muted);
				margin: 0;
			}
			.categories-nav h2 {
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--text-muted);
				margin: 0 0 0.85em;
				font-family: var(--font-sans);
				font-weight: 600;
			}
			.cats-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55em;
			}
			.cat-card {
				display: inline-flex;
				align-items: center;
				gap: 0.55em;
				padding: 0.5em 1em;
				border: 1px solid var(--border);
				border-radius: 999px;
				background: var(--white);
				color: var(--text);
				font-size: 0.85rem;
				font-weight: 500;
				font-family: var(--font-sans);
				text-decoration: none;
				transition: all 0.15s;
			}
			.cat-card:hover {
				border-color: var(--cat-color);
				color: var(--cat-color);
				transform: translateY(-1px);
				text-decoration: none;
			}
			.cat-card .dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: var(--cat-color);
				flex-shrink: 0;
			}
			.cat-card.all {
				--cat-color: var(--navy-900);
				font-weight: 600;
			}

			.featured {
				display: block;
				padding: 2.25em 2.5em;
				margin-bottom: 2.5em;
				background: var(--bg-muted);
				border: 1px solid var(--border);
				border-radius: 10px;
				color: inherit;
				text-decoration: none;
				transition: transform 0.15s, box-shadow 0.15s;
			}
			.featured:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
				text-decoration: none;
			}
			.featured .label {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--accent);
				font-weight: 600;
				margin-bottom: 0.85em;
			}
			.featured .meta {
				display: flex;
				gap: 0.75em;
				align-items: center;
				flex-wrap: wrap;
				margin-bottom: 0.5em;
			}
			.featured .meta .date {
				color: var(--text-muted);
				font-size: 0.85rem;
				font-family: var(--font-mono);
			}
			.featured h2 {
				font-size: clamp(1.5rem, 2.5vw, 2rem);
				margin: 0.35em 0 0.45em;
				color: var(--navy-900);
				line-height: 1.2;
			}
			.featured .excerpt {
				color: var(--text-muted);
				font-size: 1.05rem;
				margin: 0;
				max-width: 68ch;
			}
			.featured .card-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35em;
				margin-top: 1em;
			}

			.projects-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 1.25em;
			}
			.projects-grid li {
				margin: 0;
			}
			.projects-grid li a {
				display: flex;
				flex-direction: column;
				height: 100%;
				padding: 1.5em 1.6em;
				border: 1px solid var(--border);
				border-radius: 8px;
				color: inherit;
				text-decoration: none;
				transition: transform 0.15s, box-shadow 0.15s;
				background: var(--white);
			}
			.projects-grid li a:hover {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
				text-decoration: none;
			}
			.meta {
				display: flex;
				gap: 0.6em;
				align-items: center;
				margin-bottom: 0.55em;
				flex-wrap: wrap;
			}
			.meta .date {
				color: var(--text-muted);
				font-size: 0.82rem;
				font-family: var(--font-mono);
			}
			.meta .dot-sep {
				color: var(--border);
				font-size: 0.82rem;
			}
			.status {
				display: inline-block;
				padding: 0.2em 0.7em;
				font-size: 0.68rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				border-radius: 4px;
				font-weight: 600;
				font-family: var(--font-sans);
				border: 1px solid var(--border);
			}
			.status.active {
				background: color-mix(in srgb, var(--accent) 10%, transparent);
				border-color: color-mix(in srgb, var(--accent) 40%, transparent);
				color: var(--accent);
			}
			.status.wip {
				background: rgba(245, 158, 11, 0.1);
				border-color: rgba(245, 158, 11, 0.4);
				color: #b45309;
			}
			.status.archived {
				background: var(--bg-muted);
				color: var(--text-muted);
			}
			h2.title {
				font-size: 1.2rem;
				margin: 0.25em 0 0.4em;
				color: var(--navy-900);
				line-height: 1.25;
			}
			.excerpt {
				color: var(--text-muted);
				margin: 0;
				font-size: 0.93rem;
			}
			.projects-grid .card-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35em;
				margin-top: auto;
				padding-top: 1em;
			}
			.empty {
				padding: 3em 1em;
				text-align: center;
				color: var(--text-muted);
				border: 1px dashed var(--border);
				border-radius: 8px;
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="page-hero">
			<div class="hero-inner">
				<h1>Projects</h1>
				<p>
					Open-source tools, research prototypes, and experiments. A mix of finished work,
					half-baked ideas, and things that shipped and then got quietly shelved.
				</p>
			</div>
		</section>
		<main id="main-content">

			<section class="categories-nav">
				<h2>Browse by category</h2>
				<div class="cats-grid">
					<a class="cat-card all" href="/projects">
						<span class="dot"></span>
						<span>All projects</span>
					</a>
					{
						Object.entries(PROJECT_CATEGORIES).map(([name, info]) => (
							<a
								class="cat-card"
								href={`/projects/category/${info.slug}/`}
								style={`--cat-color: ${info.color};`}
							>
								<span class="dot" />
								<span>{name}</span>
							</a>
						))
					}
				</div>
			</section>

			{
				allProjects.length === 0 ? (
					<div class="empty">No projects yet. Check back soon.</div>
				) : (
					<>
						{activeProjects.length > 0 && (
							<section class="list-section">
								<div class="section-header">
									<h2>Active</h2>
									<p class="sub">
										{activeProjects.length}{' '}
										{activeProjects.length === 1 ? 'project' : 'projects'} currently in flight
									</p>
								</div>
								<ul class="projects-grid">
									{activeProjects.map((project) => (
										<li>
											<a href={`/projects/${project.id}/`}>
												<div class="meta">
													{project.data.category && (
														<ProjectCategoryChip
															category={project.data.category}
															linked={false}
														/>
													)}
													<span class={`status ${project.data.status}`}>
														{statusLabel[project.data.status]}
													</span>
													<span class="date">
														<FormattedDate date={project.data.pubDate} />
													</span>
												</div>
												<h2 class="title">{project.data.title}</h2>
												<p class="excerpt">{project.data.description}</p>
												{project.data.tags.length > 0 && (
													<div class="card-tags">
														{project.data.tags.map((t) => (
															<span class="tag">#{t}</span>
														))}
													</div>
												)}
											</a>
										</li>
									))}
								</ul>
							</section>
						)}

						<section class="list-section">
							<div class="section-header">
								<h2>All projects</h2>
							</div>
							<ul class="projects-grid">
								{allProjects.map((project) => (
									<li>
										<a href={`/projects/${project.id}/`}>
											<div class="meta">
												{project.data.category && (
													<ProjectCategoryChip
														category={project.data.category}
														linked={false}
													/>
												)}
												<span class={`status ${project.data.status}`}>
													{statusLabel[project.data.status]}
												</span>
												<span class="date">
													<FormattedDate date={project.data.pubDate} />
												</span>
											</div>
											<h2 class="title">{project.data.title}</h2>
											<p class="excerpt">{project.data.description}</p>
											{project.data.tags.length > 0 && (
												<div class="card-tags">
													{project.data.tags.map((t) => (
														<span class="tag">#{t}</span>
													))}
												</div>
											)}
										</a>
									</li>
								))}
							</ul>
						</section>
					</>
				)
			}
		</main>
		<Footer />
	</body>
</html>
