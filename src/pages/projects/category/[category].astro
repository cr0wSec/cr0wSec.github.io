---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { PROJECT_CATEGORIES, SITE_TITLE, type ProjectCategoryName } from '../../../consts';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return (
		Object.entries(PROJECT_CATEGORIES) as [
			ProjectCategoryName,
			(typeof PROJECT_CATEGORIES)[ProjectCategoryName],
		][]
	).map(([name, info]) => ({
		params: { category: info.slug },
		props: {
			categoryName: name,
			color: info.color,
			description: info.description,
			projects: projects
				.filter((p) => !p.data.draft && p.data.category === name)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

interface Props {
	categoryName: ProjectCategoryName;
	color: string;
	description: string;
	projects: CollectionEntry<'projects'>[];
}

const { categoryName, color, description, projects } = Astro.props;
const statusLabel = { active: 'Active', wip: 'Work in progress', archived: 'Archived' };
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${categoryName} projects · ${SITE_TITLE}`} description={description} />
		<style define:vars={{ catColor: color }}>
			.category-hero {
				background:
					radial-gradient(circle at 18% 25%, color-mix(in srgb, var(--catColor) 28%, transparent), transparent 45%),
					linear-gradient(135deg, var(--coal-950) 0%, var(--navy-900) 60%, var(--coal-900) 100%);
				color: var(--white);
				padding: 4em 1em 3.5em;
				border-bottom: 1px solid var(--navy-700);
				position: relative;
				overflow: hidden;
			}
			.category-hero::after {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
				background-size: 48px 48px;
				mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
				pointer-events: none;
			}
			.category-hero .inner {
				max-width: var(--wide-width);
				margin: 0 auto;
				position: relative;
				z-index: 1;
			}
			.breadcrumbs {
				display: inline-flex;
				align-items: center;
				font-family: var(--font-mono);
				font-size: 0.76rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: rgba(255, 255, 255, 0.85);
				margin-bottom: 1.25em;
				font-weight: 600;
				line-height: 1;
			}
			.breadcrumbs a {
				color: rgba(255, 255, 255, 0.9);
				text-decoration: none;
			}
			.breadcrumbs a:hover {
				color: var(--catColor);
				text-decoration: none;
			}
			.breadcrumbs .sep {
				margin: 0 0.6em;
				color: rgba(255, 255, 255, 0.6);
			}
			.breadcrumbs .current {
				color: var(--white);
			}
			.category-hero h1 {
				color: var(--white);
				font-size: clamp(1.8rem, 4vw, 2.6rem);
				margin: 0 0 0.45em;
				letter-spacing: -0.015em;
				line-height: 1.15;
				display: flex;
				align-items: center;
				gap: 0.55em;
			}
			.cat-dot {
				display: inline-block;
				width: 12px;
				height: 12px;
				border-radius: 50%;
				background: var(--catColor);
				box-shadow: 0 0 18px var(--catColor);
				flex-shrink: 0;
			}
			.category-hero .sub {
				color: rgba(255, 255, 255, 0.72);
				font-size: 1.02rem;
				max-width: 60ch;
				margin: 0;
			}

			ul.projects {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 1.25em;
			}
			ul.projects li a {
				display: block;
				padding: 1.5em 1.75em;
				border: 1px solid var(--border);
				border-radius: 6px;
				color: inherit;
				text-decoration: none;
				transition: transform 0.15s, box-shadow 0.15s;
			}
			ul.projects li a:hover {
				transform: translateX(3px);
				box-shadow: var(--box-shadow);
				text-decoration: none;
			}
			.meta {
				display: flex;
				gap: 0.75em;
				align-items: center;
				margin-bottom: 0.5em;
				flex-wrap: wrap;
			}
			.status {
				display: inline-block;
				padding: 0.2em 0.7em;
				font-size: 0.68rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				border-radius: 4px;
				font-weight: 600;
				font-family: var(--font-sans);
				border: 1px solid var(--border);
			}
			.status.active {
				background: color-mix(in srgb, var(--accent) 10%, transparent);
				border-color: color-mix(in srgb, var(--accent) 40%, transparent);
				color: var(--accent);
			}
			.status.wip {
				background: rgba(245, 158, 11, 0.1);
				border-color: rgba(245, 158, 11, 0.4);
				color: #b45309;
			}
			.status.archived {
				background: var(--bg-muted);
				color: var(--text-muted);
			}
			.meta .date {
				color: var(--text-muted);
				font-size: 0.82rem;
				font-family: var(--font-mono);
			}
			h2.title {
				font-size: 1.3rem;
				margin: 0.25em 0 0.4em;
				color: var(--navy-900);
			}
			.excerpt {
				color: var(--text-muted);
				margin: 0;
				font-size: 0.95rem;
			}
			.empty {
				padding: 3em 1em;
				text-align: center;
				color: var(--text-muted);
				border: 1px dashed var(--border);
				border-radius: 8px;
			}
			.count {
				color: var(--text-muted);
				font-family: var(--font-mono);
				font-size: 0.8rem;
				margin-bottom: 1.5em;
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="category-hero">
			<div class="inner">
				<nav class="breadcrumbs" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span class="sep">›</span>
					<a href="/projects">Projects</a>
					<span class="sep">›</span>
					<span class="current" aria-current="page">{categoryName}</span>
				</nav>
				<h1><span class="cat-dot"></span>{categoryName}</h1>
				<p class="sub">{description}</p>
			</div>
		</section>
		<main id="main-content">
			<p class="count">
				{projects.length} {projects.length === 1 ? 'project' : 'projects'} in this category
			</p>
			{
				projects.length === 0 ? (
					<div class="empty">No projects in this category yet. Check back soon.</div>
				) : (
					<ul class="projects">
						{projects.map((project) => (
							<li>
								<a href={`/projects/${project.id}/`}>
									<div class="meta">
										<span class={`status ${project.data.status}`}>
											{statusLabel[project.data.status]}
										</span>
										<span class="date">
											<FormattedDate date={project.data.pubDate} />
										</span>
									</div>
									<h2 class="title">{project.data.title}</h2>
									<p class="excerpt">{project.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>
